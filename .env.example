LOCAL_UPLOAD_ENABLED=true
LOCAL_UPLOAD_HOST=0.0.0.0
LOCAL_UPLOAD_PORT=8787
LOCAL_UPLOAD_PASSWORD=Hehetoto123
LOCAL_UPLOAD_TOKEN=
LOCAL_UPLOAD_PUBLIC_URL=http://letovoai.ru:8787

PUBLIC_WEB_ENABLED=true
PUBLIC_WEB_HOST=0.0.0.0
PUBLIC_WEB_PORT=8790
PUBLIC_WEB_PUBLIC_URL=https://letovoai.ru
# Legacy option: the user-facing site now uses separate site accounts from the database.
PUBLIC_WEB_PASSWORD=

ANSWER_MODEL=gpt-4o-mini
ANALYSIS_MODEL=gpt-4o
VISION_MODEL=gpt-4o
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
OPENAI_WEB_SEARCH_MAX_TOOL_CALLS=3

MAX_CONTEXT_CHUNKS=8
CONTEXT_MESSAGES=5
QUERY_TOP_K=12
MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP_CHARS=200
MAX_INDEX_CHARS=50000
MAX_VIDEO_FRAMES=6
AUDIO_SEGMENT_SECONDS=600
TELEGRAM_UPLOAD_PART_SIZE_KB=512
TELEGRAM_UPLOAD_PIPELINE_WORKERS=8
TELEGRAM_BOT_API_UPLOAD_LIMIT_MB=1024
TELEGRAM_BOT_API_CONNECT_TIMEOUT_SECONDS=180
TELEGRAM_BOT_API_READ_TIMEOUT_SECONDS=7200
TELEGRAM_BOT_API_FAILURE_COOLDOWN_SECONDS=1800

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe


