OPENAI_API_KEY=sk-...

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_BOT_TOKEN=
BOT_SESSION_NAME=rag_memory_bot
# Legacy compatibility flag. Real VK startup now depends on API_VK.
VK_BOT_ENABLED=false
API_VK=
VK_GROUP_ID=0
VK_API_VERSION=5.199

# Backward compatibility: if TELEGRAM_BOT_TOKEN is empty, SETTINGS_BOT_TOKEN will be used.
SETTINGS_BOT_TOKEN=
SETTINGS_BOT_SESSION_NAME=rag_memory_settings_bot

STORAGE_CHAT_ID=-1001234567890
VIDEO_DOWNLOAD_CHAT_IDS=-5109571428
AUTO_INGEST_CHAT_IDS=-5109571428
# Defaults now use C:/Users/<you>/PycharmProjects/data if these paths are not set.
# VIDEO_DOWNLOAD_DIR=C:/Users/<you>/PycharmProjects/data/downloads/videos
# HOMOSAP_VIDEO_PATH=C:/Users/<you>/PycharmProjects/data/HOMOSAP.mp4

PUBLIC_ACCESS=true
DAILY_MESSAGE_LIMIT=10
AUTHORIZED_USER_IDS=
UPLOADER_USER_IDS=111111111
VK_AUTHORIZED_USER_IDS=
VK_UPLOADER_USER_IDS=

# DATABASE_PATH=C:/Users/<you>/PycharmProjects/data/rag_memory.db
# DATABASE_URL=postgresql://telegram_rag_memory_bot:change_me@127.0.0.1:5432/telegram_rag_memory_bot
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=telegram_rag_memory_bot
