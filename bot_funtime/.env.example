MC_HOST=play.example.net
MC_PORT=25565
MC_VERSION=1.21.4
MC_USERNAME=AuctionScannerBot
MC_PASSWORD=
MC_AUTH=offline
MC_BRAND=vanilla
MC_PROFILES_FOLDER=.profiles
MC_LOGIN_TIMEOUT_MS=45000
MC_CHECK_TIMEOUT_MS=120000
MC_READY_STATE_TIMEOUT_MS=30000
MC_CONNECT_RETRY_DELAY_MS=5000
MC_CONNECT_RETRY_MAX_ATTEMPTS=0
MC_LOGIN_COMMAND_TEMPLATE=/login {password}
MC_POST_LOGIN_DELAY_MS=4000
MC_POST_LOGIN_SETTLE_MS=2500
MC_SERVER_SWITCH_RETRY_ENABLED=true
MC_SERVER_SWITCH_RETRY_DELAY_MS=8000
MC_SERVER_SWITCH_RETRY_MAX_ATTEMPTS=10

AH_COMMAND=/ah
AH_OPEN_TIMEOUT_MS=20000
AH_OPEN_DELAY_MS=2500
AH_PAGE_SETTLE_MS=1800
AH_NAVIGATION_TIMEOUT_MS=10000
AH_MAX_PAGES=75
AH_NEXT_PAGE_SLOT=50
AH_IGNORE_SLOTS=45,46,47,48,49,51,52,53
AH_TAX_PERCENT=5
AH_MIN_SAMPLE=3
AH_MIN_ROI_PERCENT=8
AH_MIN_PROFIT=10000
AH_MAX_GROUPS_FOR_AI=120
AH_MAX_OPPORTUNITIES_FOR_AI=40

OPENAI_ENABLED=true
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.4

OUTPUT_DIR=out
VERBOSE=true

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3500

LIVE_VIEW_HOST=127.0.0.1
LIVE_VIEW_PORT=3501
LIVE_VIEW_PREFIX=
LIVE_VIEW_FIRST_PERSON=true
LIVE_VIEW_DISTANCE=6

RESOURCE_PACK_AUTO_ACCEPT=true
RESOURCE_PACK_DOWNLOAD_ENABLED=true
RESOURCE_PACK_DOWNLOAD_TIMEOUT_MS=30000
RESOURCE_PACK_LOADED_ACK_DELAY_MS=2500
RESOURCE_PACK_LOADED_ACK_REPEATS=2
PACKET_TRACE_LIMIT=160
